---
const talks = [
  {
    title: "Shifting Gears: From Events to Event-Driven",
    videoId: "1dWJO31wpV8",
    description: "How Motorway delivered the first event-driven system in a matter of weeks in a decoupled and isolated way.",
    url: "https://www.youtube.com/watch?v=1dWJO31wpV8",
  },
  {
    title: "APIs in the Fast Lane",
    videoId: "mFtuTPgrFbA",
    description: "Tackling the challenges of API docs, outdated SDKs, WAFs, and custom authentication logic when teams want to move fast.",
    url: "https://www.youtube.com/watch?v=mFtuTPgrFbA",
  },
];
---

<section id="talks">
  <div class="container">
    <h2 class="section-heading">Talks & Presentations</h2>
    <p class="section-intro">I regularly speak at meetups, user groups, and conferences about serverless, event-driven architecture, and AWS.</p>

    <div class="talks-grid">
      {talks.map((talk) => (
        <a href={talk.url} target="_blank" rel="noopener noreferrer" class="talk-card">
          <div class="thumbnail-container">
            <img
              src={`https://img.youtube.com/vi/${talk.videoId}/maxresdefault.jpg`}
              alt={`${talk.title} talk thumbnail`}
              loading="lazy"
            />
            <div class="play-button">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="white" stroke="none">
                <polygon points="6 3 20 12 6 21 6 3" />
              </svg>
            </div>
          </div>
          <div class="card-body">
            <h3 class="talk-title">{talk.title}</h3>
            <p class="talk-description">{talk.description}</p>
          </div>
        </a>
      ))}
    </div>

    <div class="view-all">
      <a href="https://www.youtube.com/c/RyanCormack" target="_blank" rel="noopener noreferrer" class="view-all-link">
        More on YouTube
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="12 5 19 12 12 19" />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  #talks {
    padding: 5rem 1.5rem;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-intro {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .talks-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .talk-card {
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    overflow: hidden;
  }

  .talk-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .thumbnail-container {
    position: relative;
    overflow: hidden;
    border-radius: 12px 12px 0 0;
    aspect-ratio: 16 / 9;
  }

  .thumbnail-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .play-button {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 60px;
    height: 60px;
    background: rgba(0, 0, 0, 0.6);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease;
  }

  .talk-card:hover .play-button {
    background: rgba(0, 0, 0, 0.8);
  }

  .card-body {
    padding: 1.25rem 1.5rem 1.5rem;
  }

  .talk-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .talk-description {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .view-all {
    text-align: center;
    margin-top: 2.5rem;
  }

  .view-all-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-primary);
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .view-all-link:hover {
    opacity: 0.8;
  }

  @media (min-width: 768px) {
    .talks-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    #talks {
      padding: 3.5rem 1.5rem;
    }
  }
</style>
